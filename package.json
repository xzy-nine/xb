{
  "name": "xb",
  "version": "1.16.0",
  "description": "xb enhances your Weibo.com experience",
  "keywords": [
    "browser",
    "chrome",
    "extension",
    "weibo",
    "xb"
  ],
  "homepage": "https://xb-extension.vercel.app/",
  "bugs": {
    "url": "https://github.com/nnecec/xb/issues"
  },
  "license": "GPL-3.0",
  "author": "nnecec <nnecec@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/nnecec/xb.git"
  },
  "type": "module",
  "scripts": {
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox",
    "compile": "tsc --noEmit",
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "knip": "knip",
    "lint": "oxfmt --no-error-on-unmatched-pattern && oxlint --fix --no-error-on-unmatched-pattern",
    "postinstall": "wxt prepare",
    "preinstall": "npx only-allow bun",
    "prepare": "husky",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "zip": "wxt zip",
    "zip:edge": "wxt zip -b edge",
    "zip:firefox": "wxt zip -b firefox"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@reactuses/core": "^6.3.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@videojs/react": "10.0.0-beta.24",
    "axios": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dashjs": "^5.2.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^11.11.8",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-photo-view": "^1.2.7",
    "react-router": "^7.16.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jszip": "^3.4.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@wxt-dev/module-react": "^1.2.2",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern --write",
      "oxlint --fix --no-error-on-unmatched-pattern"
    ],
    "*.json": "oxfmt --no-error-on-unmatched-pattern --write"
  },
  "packageManager": "bun@1.3.14"
}
